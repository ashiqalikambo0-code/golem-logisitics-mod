{
	"schemaVersion": 1,
	"id": "iron-golem-loot",
	"version": "${version}",
	"name": "iron golem loot",
	"description": "This is an example description! Tell everyone what your mod is about!",
	"authors": [
		"Me!"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/iron-golem-loot/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			{
				"value": "com.example.IronGolemLoot",
				"adapter": "kotlin"
			}
		],
		"client": [
			{
				"value": "com.example.client.IronGolemLootClient",
				"adapter": "kotlin"
			}
		],
		"fabric-datagen": [
			{
				"value": "com.example.client.IronGolemLootDataGenerator",
				"adapter": "kotlin"
			}
		]
	},
	"mixins": [
		"iron-golem-loot.mixins.json",
		{
			"config": "iron-golem-loot.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.2",
		"minecraft": "~26.1.2",
		"java": ">=25",
		"fabric-api": "*",
		"fabric-language-kotlin": "*"
	}
}